{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2020",
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "Node",
    "importHelpers": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "lib": ["DOM", "ES2020"],
    "types": ["node", "obsidian"]
  },
  "include": ["main.ts", "**/*.ts"]
}